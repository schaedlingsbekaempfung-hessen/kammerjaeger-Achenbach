tion class=\"elementor-section elementor-top-section elementor-element elementor-element-ef3c035 elementor-section-full_width elementor-section-stretched elementor-section-height-default elementor-section-height-default\" data-id=\"ef3c035\" data-element_type=\"section\" data-settings=\"{&quot;stretch_section&quot;:&quot;section-stretched&quot;,&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-wider\">\n\t\t\t\t\t<div class=\"elementor-column elementor-col-33 elementor-top-column elementor-element elementor-element-4f170f3\" data-id=\"4f170f3\" data-element_type=\"column\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-774e06d elementor-widget elementor-widget-image\" data-id=\"774e06d\" data-element_type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t<img fetchpriority=\"high\" decoding=\"async\" width=\"250\" height=\"246\" src=\"https:\/\/acmepestsolutions.com\/wp-content\/uploads\/2023\/03\/ant-1-3.png\" class=\"attachment-large size-large wp-image-5755\" alt=\"ant 1\" \/>\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-dd49501 elementor-widget elementor-widget-heading\" data-id=\"dd49501\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">Identification<\/h2>\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-86627fd elementor-tabs-view-horizontal elementor-widget elementor-widget-tabs\" data-id=\"86627fd\" data-element_type=\"widget\" data-widget_type=\"tabs.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<div class=\"elementor-tabs\">\n\t\t\t<div class=\"elementor-tabs-wrapper\" role=\"tablist\" >\n\t\t\t\t\t\t\t\t\t<div id=\"elementor-tab-title-1401\" class=\"elementor-tab-title elementor-tab-desktop-title\" aria-selected=\"true\" data-tab=\"1\" role=\"tab\" tabindex=\"0\" aria-controls=\"elementor-tab-content-1401\" aria-expanded=\"false\">Size<\/div>\n\t\t\t\t\t\t\t\t\t<div id=\"elementor-tab-title-1402\" class=\"elementor-tab-title elementor-tab-desktop-title\" aria-selected=\"false\" data-tab=\"2\" role=\"tab\" tabindex=\"-1\" aria-controls=\"elementor-tab-content-1402\" aria-expanded=\"false\">Color<\/div>\n\t\t\t\t\t\t\t\t\t<div id=\"elementor-tab-title-1403\" class=\"elementor-tab-title elementor-tab-desktop-title\" aria-selected=\"false\" data-tab=\"3\" role=\"tab\" tabindex=\"-1\" aria-controls=\"elementor-tab-content-1403\" aria-expanded=\"false\">Description<\/div>\n\t\t\t\t\t\t\t<\/div>\n\t\t\t<div class=\"elementor-tabs-content-wrapper\" role=\"tablist\" aria-orientation=\"vertical\">\n\t\t\t\t\t\t\t\t\t<div class=\"elementor-tab-title elementor-tab-mobile-title\" aria-selected=\"true\" data-tab=\"1\" role=\"tab\" tabindex=\"0\" aria-controls=\"elementor-tab-content-1401\" aria-expanded=\"false\">Size<\/div>\n\t\t\t\t\t<div id=\"elementor-tab-content-1401\" class=\"elementor-tab-content elementor-clearfix\" data-tab=\"1\" role=\"tabpanel\" aria-labelledby=\"elementor-tab-title-1401\" tabindex=\"0\" hidden=\"false\"><p style=\"margin: 0cm;\"><span lang=\"EN-US\" style=\"color: #0e101a;\">The average ant measures about 10 to 70 millimeters across the thorax or chest area.<\/span><\/p><\/div>\n\t\t\t\t\t\t\t\t\t<div class=\"elementor-tab-title elementor-tab-mobile-title\" aria-selected=\"false\" data-tab=\"2\" role=\"tab\" tabindex=\"-1\" aria-controls=\"elementor-tab-content-1402\" aria-expanded=\"false\">Color<\/div>\n\t\t\t\t\t<div id=\"elementor-tab-content-1402\" class=\"elementor-tab-content elementor-clearfix\" data-tab=\"2\" role=\"tabpanel\" aria-labelledby=\"elementor-tab-title-1402\" tabindex=\"0\" hidden=\"hidden\"><p style=\"margin: 0cm;\"><span lang=\"EN-US\" style=\"color: #0e101a;\">Black, dark brown, red, or tan<\/span><\/p><\/div>\n\t\t\t\t\t\t\t\t\t<div class=\"elementor-tab-title elementor-tab-mobile-title\" aria-selected=\"false\" data-tab=\"3\" role=\"tab\" tabindex=\"-1\" aria-controls=\"elementor-tab-content-1403\" aria-expanded=\"false\">Description<\/div>\n\t\t\t\t\t<div id=\"elementor-tab-content-1403\" class=\"elementor-tab-content elementor-clearfix\" data-tab=\"3\" role=\"tabpanel\" aria-labelledby=\"elementor-tab-title-1403\" tabindex=\"0\" hidden=\"hidden\"><p style=\"margin: 0cm;\"><span lang=\"EN-US\" style=\"color: #0e101a;\">Ants are divided into three parts: head, thorax and abdomen. The thorax is joined to the abdomen by nodes. A reproductive ant has wings, but every other ant has six legs. Wings are important for reproductive ants because they allow them to travel long distances and find food.<\/span><\/p><\/div>\n\t\t\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t<div class=\"elementor-column elementor-col-33 elementor-top-column elementor-element elementor-element-7db518c\" data-id=\"7db518c\" data-element_type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap\">\n\t\t\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t<div class=\"elementor-column elementor-col-33 elementor-top-column elementor-element elementor-element-2bf4f27\" data-id=\"2bf4f27\" data-element_type=\"column\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-42cca8e elementor-widget elementor-widget-heading\" data-id=\"42cca8e\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t<h2 class=\"elementor-heading-title e